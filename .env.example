# ===== LLM Configuration =====
# Priority: Ollama → Groq → Azure OpenAI
# Set MOCK_LLM=true to skip all LLM providers (default for demo)

# Option 1: Ollama (local, free)
# Install: https://ollama.com → run: ollama pull llama3
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# Option 2: Groq (cloud free tier)
# Get key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Option 3: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ===== Infrastructure =====
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentshield
REDIS_URL=redis://localhost:6379

# ===== Observability =====
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentshield
LANGCHAIN_TRACING_V2=true

# ===== App =====
NODE_ENV=development
MOCK_LLM=true
PORT=3001

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:3001