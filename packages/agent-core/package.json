{
  "name": "@agent-shield/agent-core",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist && find src -name \"*.js\" -o -name \"*.js.map\" -o -name \"*.d.ts\" -o -name \"*.d.ts.map\" 2>/dev/null | xargs rm -f; true"
  },
  "dependencies": {
    "@agent-shield/policy-engine": "workspace:*",
    "@agent-shield/security-runtime": "workspace:*",
    "@agent-shield/shared-types": "workspace:*",
    "@agent-shield/tool-registry": "workspace:*",
    "@langchain/core": "^0.3.0",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^0.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "typescript": "*"
  }
}
