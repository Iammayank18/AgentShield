{
  "name": "@agent-shield/observability",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist && find src -name \"*.js\" -o -name \"*.js.map\" -o -name \"*.d.ts\" -o -name \"*.d.ts.map\" 2>/dev/null | xargs rm -f; true"
  },
  "dependencies": {
    "@agent-shield/shared-types": "workspace:*",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
